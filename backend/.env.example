# ─────────────────────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in your real values.
# ─────────────────────────────────────────────────────────────

# ── Gmail SMTP Configuration ──────────────────────────────────
# Use your Gmail address and a Gmail App Password (NOT your account password).
#
# How to generate an App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Factor Authentication (if not already enabled)
#   3. Search for "App Passwords" → Select "Mail" → Generate
#   4. Copy the 16-character password and paste below (no spaces)
#
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_char_app_password

# ── Server Port ───────────────────────────────────────────────
PORT=5000

# ── Google Sheets Logging (Optional Bonus Feature) ───────────
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# SPREADSHEET_ID=your_google_sheet_id
